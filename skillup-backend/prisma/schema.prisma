// SkillUp Database Schema
// Prisma 7 — connection URL is in prisma.config.ts

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  university String?
  password   String
  createdAt  DateTime @default(now())

  skills          Skill[]
  projects        Project[]
  learningTargets LearningTarget[]
}

model Skill {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  category  String   // Skill group/category name (e.g., "Backend Development", "General", "Mastered")
  isChecked Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model Project {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String
  description String
  tags        String   // JSON array stored as string, e.g. '["React","Node.js"]'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  links ProjectLink[] 
}

model ProjectLink {
  id        Int      @id @default(autoincrement())
  projectId Int
  type      String   // e.g., "GitHub", "Figma", "Video"
  url       String
  
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model LearningTarget {
  id            Int      @id @default(autoincrement())
  userId        Int
  skillName     String
  targetMinutes Int      @default(30)
  deadline      String?  // ISO date string
  isCompleted   Boolean  @default(false)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
