# SkillUp Backend Environment Variables
# Copy this file to .env and fill in the values

# Groq AI API Key - used for text-only AI analysis (get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Gemini AI API Key - used for image/multimodal analysis (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret for authentication tokens (use a long random string in production)
JWT_SECRET=skillup-jwt-secret-change-in-production

# Database URL
# Use the Neon pooled connection string in production.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
